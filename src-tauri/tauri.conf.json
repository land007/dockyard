{
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  },
  "productName": "dockyard",
  "mainBinaryName": "dockyard",
  "version": "0.5.0",
  "identifier": "ropali.dockyard.dev",
  "plugins": {},
  "app": {
    "security": {
      "csp": null,
      "capabilities": [
        "desktop-core-capabilities",
        "desktop-fs-capabilities",
        "desktop-shell-capabilities",
        "desktop-store-capabilities",
        "desktop-updater-capabilities"
      ]
    },
    "windows": [
      {
        "title": "Dockyard",
        "width": 1200,
        "height": 800,
        "useHttpsScheme": true
      }
    ]
  }
}